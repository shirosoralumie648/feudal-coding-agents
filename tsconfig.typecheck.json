{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "jsx": "react-jsx",
    "types": ["node"]
  },
  "include": ["apps/**/*.ts", "apps/**/*.tsx", "packages/**/*.ts"],
  "exclude": [
    "node_modules",
    "dist",
    "coverage",
    "test-results",
    "playwright-report",
    ".worktrees",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/e2e/**"
  ]
}
